<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!-- Cấu hình chuỗi kết nối MySQL (bạn cần đổi mật khẩu nếu có) -->
    <add name="MySQLConnection" 
         connectionString="Server=localhost;Database=quan_ly_chi_tieu;Uid=root;Pwd=abc@123;" 
         providerName="MySql.Data.MySqlClient" />
  </connectionStrings>
  
  <system.web>
    <compilation debug="true" targetFramework="4.8">
      <assemblies>
        <add assembly="MySql.Data, Version=8.0.33.0, Culture=neutral, PublicKeyToken=c5687fc88969c44d" />
      </assemblies>
    </compilation>
    <httpRuntime targetFramework="4.8" />
    <globalization fileEncoding="utf-8" requestEncoding="utf-8" responseEncoding="utf-8" culture="vi-VN" uiCulture="vi-VN" />
    
    <!-- Cấu hình bảo mật Form Authentication -->
    <authentication mode="Forms">
      <forms loginUrl="~/Account/Login.aspx" timeout="2880" defaultUrl="~/Default.aspx" />
    </authentication>
    
    <authorization>
      <!-- Từ chối người dùng chưa đăng nhập -->
      <deny users="?"/>
    </authorization>
  </system.web>

  <!-- Cho phép truy cập trang Đăng nhập mà không cần đăng nhập -->
  <location path="Account/Login.aspx">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>

  <!-- Cho phép truy cập trang Đăng ký mà không cần đăng nhập -->
  <location path="Account/Register.aspx">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>

  <!-- Cho phép tải CSS mà không cần đăng nhập -->
  <location path="Assets">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>

  <system.webServer>
    <defaultDocument>
      <files>
        <add value="Default.aspx" />
      </files>
    </defaultDocument>
  </system.webServer>
</configuration>
